# Local development default.
# For the standard Docker Compose deployment on Hetzner, you normally do not need to change this value:
# compose.yaml overrides DATABASE_URL inside the container with file:/app/data/dev.db.
# Only change this for local special cases or bare-metal deployments without Docker.
DATABASE_URL="file:./dev.db"

# Required for every public instance. Use at least 32 random characters in production.
SESSION_SECRET="replace-with-a-long-random-string"

# Admin bootstrap credentials. Replace all values before any public deployment.
ADMIN_EMAIL="demo@klarraum-ruhr.de"
ADMIN_PASSWORD="ChangeMe123!"
ADMIN_NAME="Administrator"

# Runtime defaults for the single-instance start script.
# In the standard Docker Compose setup on Hetzner, these values are already set by compose.yaml.
RUN_DB_MIGRATE_ON_START="true"
HOSTNAME="0.0.0.0"
PORT="3000"

# Optional: provide all COMPANY_* values to create company settings during bootstrap.
# Leave them empty if you prefer to enter company data manually in the admin UI afterwards.
# COMPANY_NAME="Muster Entruempelung GmbH"
# COMPANY_EMAIL="kontakt@ihr-betrieb.de"
# COMPANY_PHONE="+49 201 123456"
# COMPANY_WEBSITE="https://www.ihre-domain.de"
# COMPANY_STREET="Musterstrasse 1"
# COMPANY_POSTAL_CODE="45127"
# COMPANY_CITY="Essen"
# COMPANY_SERVICE_AREA_NOTE="Essen, Muelheim, Oberhausen und das westliche Ruhrgebiet"
# COMPANY_ESTIMATE_FOOTNOTE="Die angezeigte Kostenschaetzung ist unverbindlich und dient der ersten Orientierung."
# COMPANY_SUPPORT_HOURS="Mo-Fr 08:00-18:00"
