# Local development default. For Docker or a Linux host, use an explicit file path outside the repository checkout.
DATABASE_URL="file:./dev.db"

# Required in every non-local environment. Use at least 32 random characters in production.
SESSION_SECRET="replace-with-a-long-random-string"

# Admin bootstrap credentials. Replace both values before the first customer installation.
ADMIN_EMAIL="demo@klarraum-ruhr.de"
ADMIN_PASSWORD="ChangeMe123!"
ADMIN_NAME="Demo Admin"

# Runtime defaults for the single-instance start script.
RUN_DB_MIGRATE_ON_START="true"
HOSTNAME="0.0.0.0"
PORT="3000"

# Optional: provide all COMPANY_* values to create company settings during bootstrap.
# Leave all of them empty if you prefer to enter company data manually in the admin UI afterwards.
# COMPANY_NAME="Muster Entrümpelung GmbH"
# COMPANY_EMAIL="kontakt@example.de"
# COMPANY_PHONE="+49 201 123456"
# COMPANY_WEBSITE="https://www.example.de"
# COMPANY_STREET="Musterstraße 1"
# COMPANY_POSTAL_CODE="45127"
# COMPANY_CITY="Essen"
# COMPANY_SERVICE_AREA_NOTE="Essen, Mülheim, Oberhausen und das westliche Ruhrgebiet"
# COMPANY_ESTIMATE_FOOTNOTE="Die angezeigte Kostenschätzung ist unverbindlich und dient der ersten Orientierung."
# COMPANY_SUPPORT_HOURS="Mo-Fr 08:00-18:00"
